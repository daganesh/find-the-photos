# Copy to .env and fill in. All keys come from Google Cloud Console.

# --- Google Sign-In (OAuth 2.0 Web client) ---
# Used by BOTH the web app (to render the sign-in button) and the server
# (to verify ID tokens). Same value in both places.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# --- Gemini (server only — never exposed to the browser) ---
GEMINI_API_KEY=your-gemini-api-key
# Model used for image comparison.
GEMINI_MODEL=gemini-2.0-flash

# --- Google Maps (web only) ---
GOOGLE_MAPS_API_KEY=your-maps-browser-key

# --- Server ---
PORT=4000
# Where the web app is served from (for CORS).
WEB_ORIGIN=http://localhost:5173
# Secret used to sign session tokens.
SESSION_SECRET=change-me-to-a-long-random-string

# --- Web (Vite needs the VITE_ prefix to expose to the browser) ---
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_MAPS_API_KEY=your-maps-browser-key
VITE_API_BASE_URL=http://localhost:4000
